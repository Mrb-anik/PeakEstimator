# ══════════════════════════════════════════════════════════════════
# PeakEstimator — Environment Variables Reference
# Copy to .env.local and fill in real values. Never commit .env.local
# ══════════════════════════════════════════════════════════════════

# ─── Frontend (Vite) ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Cal.com Booking Link (default is peakestimator/30min)
VITE_CAL_BOOKING_LINK=peakestimator/30min

# ─── Supabase Edge Function Secrets ──────────────────────────────
# Set these in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# (Do NOT put them in .env.local — they are server-side only)
#
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_URL=https://your-project.supabase.co
# SITE_URL=https://peakestimator.top
#
# Stripe (required for stripe-checkout, stripe-webhook edge functions)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ENTERPRISE_PRICE_ID=price_...
#
# Email (required for email-followup, notify-contractor edge functions)
# RESEND_API_KEY=re_...
# FROM_EMAIL=noreply@peakestimator.com
#
# AI (required for ai-estimator, ai-transcribe edge functions)
# OPENROUTER_API_KEY=sk-or-...  # Get from openrouter.ai/keys
#
# Auth Hook Secret (required for track-login edge function)
# TRACK_LOGIN_HOOK_SECRET=generate-a-random-secret-here
# MONTHLY_RESET_SECRET=generate-a-random-secret-here
#
# PDF Generation (required for generate-pdf)
# PDF_SERVICE_URL=https://...  (or leave blank to use browser-based generation)


# ─── Additional Required Secrets (Edge Function environment) ──────
# OPENROUTER_API_KEY=sk-or-...      (REQUIRED for ai-estimator, ai-transcribe)
# RESEND_API_KEY=re_...             (REQUIRED for email-followup, notify-contractor)
# STRIPE_SECRET_KEY=sk_live_...     (REQUIRED for stripe-checkout, stripe-webhook)
# STRIPE_WEBHOOK_SECRET=whsec_...   (REQUIRED for stripe-webhook)
# SITE_URL=https://peakestimator.top
# SUPABASE_SERVICE_ROLE_KEY=...     (REQUIRED for admin-manager, all Edge Functions)
